# endpoints.env — Environment variables for zallet-rpc-diff
#
# Copy this file to .env (or source it in your shell) before running the harness.
# Do NOT commit real credentials. This file is an example only.
#
# Usage:
#   source examples/endpoints.env
#   zallet-rpc-diff run
#
# Or pass values directly as CLI flags:
#   zallet-rpc-diff run \
#     --upstream-url http://user:pass@127.0.0.1:8232 \
#     --target-url   http://user:pass@127.0.0.1:9067

# ─── Upstream: zcashd ────────────────────────────────────────────────────────
# The source-of-truth node. Typically a fully-synced zcashd instance.
# RPC port default: 8232 (mainnet), 18232 (testnet)
UPSTREAM_URL=http://rpcuser:rpcpassword@127.0.0.1:8232

# ─── Target: Zallet ──────────────────────────────────────────────────────────
# The node under test. Port depends on your Zallet configuration.
TARGET_URL=http://rpcuser:rpcpassword@127.0.0.1:9067

# ─── Optional overrides ──────────────────────────────────────────────────────
# RUST_LOG=info              # Tracing verbosity: error | warn | info | debug | trace
# RUST_LOG=zallet_parity_core=debug
